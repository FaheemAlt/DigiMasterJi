# ===== AWS Configuration =====
# AWS Region for all services
AWS_REGION=us-east-1

# AWS Credentials (or use IAM roles in production)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ===== DynamoDB Tables =====
DYNAMODB_USERS_TABLE=digimasterji-users
DYNAMODB_PROFILES_TABLE=digimasterji-profiles
DYNAMODB_CONVERSATIONS_TABLE=digimasterji-conversations
DYNAMODB_MESSAGES_TABLE=digimasterji-messages
DYNAMODB_QUIZZES_TABLE=digimasterji-quizzes
DYNAMODB_KNOWLEDGE_BASE_TABLE=digimasterji-knowledge-base

# ===== Amazon Bedrock =====
# LLM Model ID Nova Lite ID (us.amazon.nova-lite-v1:0)
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# Bedrock Knowledge Base (for RAG)
BEDROCK_KNOWLEDGE_BASE_ID=your-knowledge-base-id
BEDROCK_DATA_SOURCE_ID=your-data-source-id

# ===== MongoDB Atlas (Bedrock KB Embeddings) =====
# MongoDB Atlas connection string for querying bedrock_embeddings collection
# This is where AWS Bedrock stores the vector embeddings
MONGODB_URI=
MONGODB_KB_DATABASE=digimasterji_kb
MONGODB_KB_COLLECTION=bedrock_embeddings

# ===== Amazon S3 =====
# S3 bucket for knowledge base documents
S3_KNOWLEDGE_BUCKET=digimasterji-knowledge

# ===== JWT Configuration =====
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== App Configuration =====
APP_NAME=DigiMasterji
DEBUG=True

# ===== STT (Speech-to-Text) Settings =====
# STT Provider: 'deepgram' (uses Deepgram cloud API)
STT_PROVIDER=deepgram

# Language detection mode: 'profile' (use user's preferred_language) or 'auto' (auto-detect from audio)
STT_LANGUAGE_MODE=auto

# Deepgram Settings (required)
DEEPGRAM_API_KEY=your-deepgram-api-key
# Deepgram Whisper model: whisper, whisper-tiny, whisper-base, whisper-small, whisper-medium, whisper-large
DEEPGRAM_MODEL=whisper-large

# ===== RAG Configuration Parameters =====
CHAT_HISTORY_LIMIT=10  # Number of previous messages for context
RAG_CHUNKS_LIMIT=5     # Number of knowledge chunks to retrieve
RAG_MIN_SCORE=0.3      # Minimum similarity score threshold
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
SKIP_STARTUP_QUIZ=true

# ===== Sync Configuration =====
SYNC_DEFAULT_DAYS=180  # Default number of days of messages to sync
SYNC_MAX_DAYS=365      # Maximum allowed days for sync